# Copie este arquivo para .env e preencha os valores

# Gere uma chave com: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=troque-por-uma-chave-secreta-longa

# True em dev, False em produção
DEBUG=True

# Separados por vírgula. Em produção: seu-app.onrender.com
ALLOWED_HOSTS=localhost,127.0.0.1

# Deixe em branco para usar SQLite localmente.
# O Render preenche isso automaticamente quando você adiciona um banco PostgreSQL.
DATABASE_URL=
